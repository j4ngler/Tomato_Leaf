# Sao chép file này thành `.env` trong cùng thư mục (TomatoLeaf_v2).
# File `.env` không được commit (đã nằm trong .gitignore).

# Cách 1: Một URL đầy đủ (ưu tiên)
# CAM_RTSP_URL=rtsp://admin:MAT_KHAU@192.168.1.57:554/cam/realmonitor?channel=1&subtype=0

# Cách 2: Giống camera_control/test_rtsp.py & schedule_hourly_continuous_ptz.py
RTSP_USER=admin
RTSP_PASS=your_password_here
RTSP_HOST=192.168.1.57
RTSP_PORT=554
RTSP_PATH=/cam/realmonitor?channel=1&subtype=0

# PTZ ONVIF (tùy chọn — cổng HTTP, không dùng 554)
# CAM_IP=192.168.1.57
# CAM_USER=admin
# CAM_PASS=your_onvif_password
# ONVIF_PORT=80
